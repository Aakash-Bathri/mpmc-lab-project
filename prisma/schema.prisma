generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model VehicleLog {
  id             String    @id @default(uuid())
  plateNumber    String
  ownerName      String?
  drivingLicense String?
  entryTime      DateTime  @default(now())
  exitTime       DateTime?
  isNITTExempt   Boolean   @default(false)
}
