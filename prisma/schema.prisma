generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VehicleLog {
  id             String    @id @default(uuid())
  plateNumber    String
  ownerName      String?
  drivingLicense String?
  entryTime      DateTime  @default(now())
  exitTime       DateTime?
  isNITTExempt   Boolean   @default(false)
}
